# ─── DATABASE ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/beautyflow"

# ─── REDIS ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── OPENAI ─────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"
OPENAI_TIMEOUT_MS=19000

# ─── WHATSAPP / META ────────────────────────────────────────
META_APP_SECRET="..."
META_ACCESS_TOKEN="..."
META_PHONE_NUMBER_ID="..."
META_VERIFY_TOKEN="..."  # token de verificação do webhook

# ─── GATEWAY DE PAGAMENTO ───────────────────────────────────
ASSAS_API_KEY="$aact_..."
ASSAS_WEBHOOK_TOKEN="..."
ASSAS_ENVIRONMENT="sandbox"  # ou "production"

# ─── SEGURANÇA ──────────────────────────────────────────────
JWT_SECRET="mude-para-um-segredo-forte-com-no-minimo-32-chars"
JWT_EXPIRES_IN="15m"             # access token: curto por segurança
JWT_REFRESH_SECRET="outro-segredo-diferente-do-jwt-secret-tambem-32chars"
JWT_REFRESH_EXPIRES_IN="30d"     # refresh token: longa duração
CPF_ENCRYPTION_KEY="..."         # AES-256, 32 bytes em hex

# ─── CORS ───────────────────────────────────────────────────
# Em produção, liste as origins permitidas separadas por vírgula (sem espaços)
# Ex: ALLOWED_ORIGINS="https://app.beautyflow.com.br,https://admin.beautyflow.com.br"
ALLOWED_ORIGINS="http://localhost:3001,http://localhost:5173"

# ─── RATE LIMITING ──────────────────────────────────────────
THROTTLE_TTL=60000    # janela em ms (padrão: 60s)
THROTTLE_LIMIT=100    # máx requisições por janela por IP (padrão: 100)

# ─── APP ────────────────────────────────────────────────────
NODE_ENV="development"  # "production" desabilita Swagger e mensagens de erro detalhadas
PORT=3000
APP_URL="http://localhost:3000"
SWAGGER_ENABLED="true"  # force true em produção se necessário
