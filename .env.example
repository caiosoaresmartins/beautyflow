# ── Banco de Dados ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xyz.neon.tech/beautyflow?sslmode=require"

# ── Redis (Upstash Free) ──────────────────────────────────────────────────────
REDIS_URL="rediss://default:token@endpoint.upstash.io:6379"

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
ALLOWED_ORIGINS="http://localhost:3001,https://app.beautyflow.com.br"

# ── OpenAI / Groq ────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
GROQ_API_KEY="gsk_..."          # Alternativa gratuita para dev
USE_GROQ="false"                # true = usa Groq (free), false = usa OpenAI

# ── Meta WhatsApp Business ───────────────────────────────────────────────────
META_APP_SECRET="meta-app-secret-para-validacao-hmac"
META_WEBHOOK_VERIFY_TOKEN="token-de-verificacao-do-webhook"
META_ACCESS_TOKEN="EAAxxxx..."  # Token de acesso da API
META_PHONE_NUMBER_ID="xxxx"     # ID do número de telefone no Meta

# ── Asaas (Billing) ──────────────────────────────────────────────────────────
ASSAS_API_KEY="$aact_xxx..."           # Chave da API Asaas
ASSAS_BASE_URL="https://sandbox.asaas.com/api/v3"  # Trocar para produção
ASSAS_WEBHOOK_TOKEN="token-secreto-configurado-no-painel-asaas"

# ── Sentry (Observabilidade) ─────────────────────────────────────────────────
SENTRY_DSN="https://xxx@sentry.io/xxx"
