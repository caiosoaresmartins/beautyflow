# ─── DATABASE ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/beautyflow"

# ─── REDIS ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── OPENAI ─────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"
OPENAI_TIMEOUT_MS=19000

# ─── WHATSAPP / META ────────────────────────────────────────
META_APP_SECRET="..."
META_ACCESS_TOKEN="..."
META_PHONE_NUMBER_ID="..."
META_VERIFY_TOKEN="..."  # token de verificação do webhook

# ─── GATEWAY DE PAGAMENTO ───────────────────────────────────
ASSAS_API_KEY="$aact_..."
ASSAS_WEBHOOK_TOKEN="..."
ASSAS_ENVIRONMENT="sandbox"  # ou "production"

# ─── SEGURANÇA ──────────────────────────────────────────────
JWT_SECRET="..."
JWT_EXPIRES_IN="7d"
CPF_ENCRYPTION_KEY="..."  # AES-256, 32 bytes em hex

# ─── APP ────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
APP_URL="http://localhost:3000"
