# ─── Banco de Dados ─────────────────────────────────────────────────────────
# Neon (recomendado free tier): https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xyz.neon.tech/beautyflow?sslmode=require"

# ─── Cache / Idempotência ───────────────────────────────────────────────────
# Upstash Redis (recomendado free tier): https://upstash.com
REDIS_URL="redis://default:token@endpoint.upstash.io:6379"

# ─── Autenticação JWT ────────────────────────────────────────────────────────
JWT_SECRET="troque-por-string-aleatoria-com-64-chars-no-minimo"
JWT_EXPIRATION="7d"

# ─── Segurança ───────────────────────────────────────────────────────────────
# Chave para criptografia AES-256 de CPF/CNPJ
AES_SECRET_KEY="troque-por-chave-secreta-32-chars-minimo"

# CORS — origens permitidas (separadas por vírgula)
ALLOWED_ORIGINS="http://localhost:3001,https://seu-frontend.vercel.app"

# ─── WhatsApp / Meta ─────────────────────────────────────────────────────────
META_ACCESS_TOKEN=""
META_PHONE_NUMBER_ID=""
META_VERIFY_TOKEN="seu-verify-token-personalizado"
META_APP_SECRET=""

# ─── IA ──────────────────────────────────────────────────────────────────────
# OpenAI (produção)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# Groq (desenvolvimento/gratuito) — se definido, substitui OpenAI
GROQ_API_KEY=""

# ─── Pagamentos / Asaas ──────────────────────────────────────────────────────
ASSAS_ENVIRONMENT="sandbox"   # sandbox | production
ASSAS_API_KEY=""
ASSAS_WEBHOOK_TOKEN=""        # token para validar webhooks do Asaas

# ─── Ambiente ────────────────────────────────────────────────────────────────
NODE_ENV="development"        # development | test | production
PORT="3000"
