// BeautyFlow — Prisma Schema
// Versão: 0.6 | Fase 2+3: campos WhatsApp, Notificações e Billing

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANT ────────────────────────────────────────────────────────────────

model Salon {
  id                    String   @id @default(cuid())
  name                  String
  timezone              String   @default("America/Sao_Paulo")
  cnpj                  String?  // armazenado criptografado via AES-256 no app layer
  whatsappPhoneNumberId String?  // phoneNumberId da Meta para roteamento de webhooks
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  professionals Professional[]
  services      Service[]
  bookings      Booking[]
  subscriptions Subscription[]
  plans         Plan[]
  holidays      SalonHoliday[]
  webhookEvents WebhookEvent[]
  conversations ConversationMessage[]

  @@map("salons")
}

// ─── PROFISSIONAL ───────────────────────────────────────────────────────────

model Professional {
  id                 String           @id @default(cuid())
  salonId            String
  name               String
  email              String           @unique  // fix CRÍTICO-02: campo de autenticação
  passwordHash       String                    // fix CRÍTICO-02: campo de autenticação
  phone              String?                   // fix CRÍTICO-02: contato
  bio                String?                   // descrição do profissional
  role               ProfessionalRole @default(PROFESSIONAL)
  gatewayRecipientId String?          // walletId/recipientId no gateway
  commissionRules    CommissionRule[]
  workingHours       WorkingHours[]
  leaveBlocks        LeaveBlock[]
  bookings           Booking[]
  salon              Salon            @relation(fields: [salonId], references: [id])
  createdAt          DateTime         @default(now())

  @@map("professionals")
}

enum ProfessionalRole {
  OWNER
  PROFESSIONAL
  RECEPTIONIST
}

model WorkingHours {
  id             String       @id @default(cuid())
  professionalId String
  dayOfWeek      Int          // 0=Dom ... 6=Sab
  startTime      String       // "09:00" — hora local do salão
  endTime        String       // "18:00"
  professional   Professional @relation(fields: [professionalId], references: [id])

  @@unique([professionalId, dayOfWeek])
  @@map("working_hours")
}

model LeaveBlock {
  id             String       @id @default(cuid())
  professionalId String
  startsAt       DateTime     // UTC
  endsAt         DateTime     // UTC
  reason         String?
  professional   Professional @relation(fields: [professionalId], references: [id])

  @@map("leave_blocks")
}

model SalonHoliday {
  id      String   @id @default(cuid())
  salonId String
  date    DateTime // UTC
  name    String
  salon   Salon    @relation(fields: [salonId], references: [id])

  @@map("salon_holidays")
}

// ─── SERVIÇO ────────────────────────────────────────────────────────────────

model Service {
  id              String           @id @default(cuid())
  salonId         String
  name            String
  durationMinutes Int              // duração real por serviço
  priceDefault    Decimal          @db.Decimal(10, 2)
  category        String
  active          Boolean          @default(true)
  salon           Salon            @relation(fields: [salonId], references: [id])
  commissionRules CommissionRule[]
  bookings        Booking[]

  @@map("services")
}

model CommissionRule {
  id              String       @id @default(cuid())
  professionalId  String
  serviceId       String?      // null = regra padrão do profissional
  percentage      Decimal      @db.Decimal(5, 2)  // percentual do profissional
  professionalPct Decimal      @db.Decimal(5, 2)  // ex: 60.00
  salonPct        Decimal      @db.Decimal(5, 2)  // ex: 25.00
  platformPct     Decimal      @db.Decimal(5, 2)  // ex: 15.00
  // Constraint app layer: professionalPct + salonPct + platformPct = 100
  professional    Professional @relation(fields: [professionalId], references: [id])
  service         Service?     @relation(fields: [serviceId], references: [id])

  @@map("commission_rules")
}

// ─── AGENDAMENTO ────────────────────────────────────────────────────────────

model Booking {
  id              String        @id @default(cuid())
  salonId         String
  clientId        String
  professionalId  String
  serviceId       String
  subscriptionId  String?
  startsAt        DateTime
  endsAt          DateTime
  status          BookingStatus @default(CONFIRMED)
  noShowFee       Decimal?      @db.Decimal(10, 2)
  cancelledAt     DateTime?
  rescheduledFrom String?       // bookingId anterior
  reminderSentAt  DateTime?     // controla envio de lembrete 24h — evita duplicatas
  deletedAt       DateTime?     // soft delete
  createdAt       DateTime      @default(now())

  salon        Salon         @relation(fields: [salonId], references: [id])
  client       Client        @relation(fields: [clientId], references: [id])
  professional Professional  @relation(fields: [professionalId], references: [id])
  service      Service       @relation(fields: [serviceId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  charges      Charge[]

  @@index([professionalId, startsAt, endsAt])
  @@index([salonId, startsAt])
  @@index([startsAt, reminderSentAt]) // índice para a query de lembretes
  @@map("bookings")
}

enum BookingStatus {
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  PENDING
  PENDING_PAYMENT
}

// ─── CLIENTE ────────────────────────────────────────────────────────────────

model Client {
  id                String    @id @default(cuid())
  salonId           String
  whatsappId        String?   // número E.164 — opcional para clientes criados pelo admin
  name              String
  email             String?   // fix CRÍTICO-04: campo adicionado
  phone             String?   // fix CRÍTICO-04: campo adicionado
  notes             String?   // fix CRÍTICO-04: campo adicionado
  cpf               String?   // criptografar AES-256 antes de persistir
  optedOut          Boolean   @default(false)
  optedOutAt        DateTime?
  gatewayCustomerId String?   // ID do customer no Asaas (Billing)
  createdAt         DateTime  @default(now())
  deletedAt         DateTime? // soft delete

  bookings      Booking[]
  subscriptions Subscription[]
  conversations ConversationMessage[]

  @@unique([salonId, whatsappId])
  @@map("clients")
}

// ─── PLANO & ASSINATURA ─────────────────────────────────────────────────────

model Plan {
  id              String   @id @default(cuid())
  salonId         String
  name            String
  price           Decimal  @db.Decimal(10, 2)  // alias para priceMonthly
  priceMonthly    Decimal  @db.Decimal(10, 2)
  billingCycleDay Int      // dia do mês (1–28)
  creditsPerCycle Int      // nº de serviços incluídos por ciclo
  currency        String   @default("BRL")
  gatewayPlanId   String?
  active          Boolean  @default(true)
  salon           Salon    @relation(fields: [salonId], references: [id])
  subscriptions   Subscription[]

  @@map("plans")
}

model Subscription {
  id                    String             @id @default(cuid())
  salonId               String
  clientId              String
  planId                String
  status                SubscriptionStatus @default(ACTIVE)
  gatewaySubId          String?
  gatewaySubscriptionId String?            // ID retornado pelo Asaas
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  currentCycleStart     DateTime?
  currentCycleEnd       DateTime?
  creditsUsed           Int                @default(0)
  creditsTotal          Int                @default(0)
  createdAt             DateTime           @default(now())
  cancelledAt           DateTime?
  pastDueAt             DateTime?

  client   Client   @relation(fields: [clientId], references: [id])
  plan     Plan     @relation(fields: [planId], references: [id])
  bookings Booking[]
  salon    Salon   @relation(fields: [salonId], references: [id])
  charges  Charge[]

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
  PENDING
}

// ─── COBRANÇA & SPLIT ───────────────────────────────────────────────────────

model Charge {
  id              String       @id @default(cuid())
  salonId         String
  bookingId       String?
  subscriptionId  String?
  clientId        String?
  grossAmount     Decimal?     @db.Decimal(10, 2)
  netAmount       Decimal?     @db.Decimal(10, 2)
  amount          Decimal?     @db.Decimal(10, 2)  // usado pelo BillingService
  currency        String       @default("BRL")
  status          ChargeStatus @default(PENDING)
  gatewayChargeId String?
  paidAt          DateTime?
  refundedAt      DateTime?
  refundedAmount  Decimal?     @db.Decimal(10, 2)
  splits          ChargeSplit[]
  booking         Booking?     @relation(fields: [bookingId], references: [id])
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])

  @@map("charges")
}

enum ChargeStatus {
  PENDING
  CONFIRMED
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
  FAILED
  CANCELLED
}

model ChargeSplit {
  id                 String        @id @default(cuid())
  chargeId           String
  recipientType      RecipientType
  recipientId        String
  bookingId          String?
  gatewayRecipientId String?
  percentage         Decimal       @db.Decimal(5, 2)
  amount             Decimal       @db.Decimal(10, 2)
  status             SplitStatus   @default(PENDING)
  reversedAt         DateTime?
  charge             Charge        @relation(fields: [chargeId], references: [id])

  @@map("charge_splits")
}

enum RecipientType {
  PROFESSIONAL
  SALON
  PLATFORM
}

enum SplitStatus {
  PENDING
  DONE
  REFUNDED
  FAILED
}

// ─── IDEMPOTÊNCIA DE WEBHOOKS ───────────────────────────────────────────────

model WebhookEvent {
  id              String   @id @default(cuid())
  gatewayEventId  String   @unique  // ID único do evento vindo do gateway/Meta
  salonId         String?
  source          String?  // "ASAAS" | "META_WHATSAPP"
  type            String?  // tipo do evento ex: PAYMENT_RECEIVED
  payload         String   @db.Text
  processedAt     DateTime @default(now())
  salon           Salon?   @relation(fields: [salonId], references: [id])

  @@map("webhook_events")
}

// ─── CONVERSA / IA ──────────────────────────────────────────────────────────

model ConversationMessage {
  id        String    @id @default(cuid())
  clientId  String
  salonId   String
  role      String    // "user" | "assistant" | "tool"
  content   String    @db.Text
  tokens    Int?
  createdAt DateTime  @default(now())
  expiresAt DateTime? // retenção com TTL (LGPD: 30 dias)

  client Client @relation(fields: [clientId], references: [id])
  salon  Salon  @relation(fields: [salonId], references: [id])

  @@index([clientId, createdAt])
  @@index([expiresAt])  // índice para limpeza periódica de mensagens expiradas
  @@map("conversation_messages")
}
